{
  "name": "carebridge-navigator",
  "version": "0.1.0",
  "type": "module",
  "description": "Offline-first SDG 3 care navigation tool for community health workers.",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "keywords": [
    "sdg-3",
    "community-health",
    "care-navigation",
    "offline-first",
    "universal-health-coverage"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "check:release": "npm test && npm run typecheck && npm run check:security && npm run check:accessibility && npm run build && npm run check:ui && npm run check:submission",
    "check:accessibility": "node scripts/check-accessibility.mjs",
    "check:public-repo": "node scripts/check-public-repo.mjs",
    "check:submission": "node scripts/check-submission.mjs",
    "check:security": "npm audit --audit-level=moderate && node scripts/check-code-safety.mjs",
    "check:ui": "node scripts/check-ui.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "lucide-react": "^0.556.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
